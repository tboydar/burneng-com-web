---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-coal">
  <!-- Fire glow background -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="w-[600px] h-[600px] rounded-full bg-ember/10 blur-[120px]"></div>
    <div class="absolute w-[400px] h-[400px] rounded-full bg-flame/10 blur-[80px]"></div>
  </div>

  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <p class="text-glow/80 text-sm font-inter uppercase tracking-widest mb-4">AI 共燃英語團</p>
    <h1 class="text-5xl md:text-7xl font-black text-ash leading-tight mb-6">
      用 AI 把英文<br/>
      <span class="text-ember">燒</span>進日常
    </h1>
    <p class="text-xl md:text-2xl text-ash/70 mb-12 max-w-xl mx-auto">
      21 天，一群英文不夠好的人，一起慢慢變好
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/join" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-ember text-coal font-bold rounded-lg hover:bg-flame transition-colors text-lg">
        我要 AI 共燃 🔥
      </a>
      <a href="/join#pacemaker" class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-ash/30 text-ash font-bold rounded-lg hover:border-glow hover:text-glow transition-colors text-lg">
        我要陪跑
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-ash/40 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
  </div>
</section>