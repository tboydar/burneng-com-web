---
import FireCanvas from './FireCanvas.astro';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-coal">
  <!-- p5.js fire animation -->
  <FireCanvas />

  <!-- Bottom fade into next section -->
  <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-coal via-coal/80 to-transparent pointer-events-none z-10"></div>

  <div class="relative z-20 text-center px-6 max-w-4xl mx-auto">
    <!-- Tag line -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-ember/30 bg-ember/10 mb-8">
      <span class="w-2 h-2 rounded-full bg-ember animate-pulse"></span>
      <span class="text-glow/90 text-sm font-inter tracking-wider">21 天 AI 輔助英語共學</span>
    </div>

    <!-- Main heading -->
    <h1 class="text-5xl md:text-8xl font-black text-ash leading-none mb-6 tracking-tight">
      用 AI 把英文<br/>
      <span class="relative inline-block">
        <span class="text-ember">燒</span>
        <span class="absolute -inset-2 bg-ember/20 rounded-lg blur-lg -z-10"></span>
      </span>
      進日常
    </h1>

    <!-- Subheading -->
    <p class="text-lg md:text-2xl text-ash/60 mb-12 max-w-xl mx-auto font-light">
      一群英文不夠好的人，<br class="md:hidden"/>一起用 AI 慢慢變好
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a href="/join" class="group relative inline-flex items-center gap-3 px-8 py-4 bg-ember text-coal font-black text-lg rounded-xl overflow-hidden transition-transform hover:scale-105 active:scale-95">
        <span class="relative z-10">我要 AI 共燃</span>
        <span class="relative z-10 text-coal/70">🔥</span>
        <div class="absolute inset-0 bg-gradient-to-r from-flame to-ember opacity-0 group-hover:opacity-100 transition-opacity"></div>
      </a>
      <a href="/join#pacemaker" class="group inline-flex items-center gap-3 px-8 py-4 border-2 border-ash/20 text-ash/80 font-bold text-lg rounded-xl hover:border-glow/60 hover:text-glow transition-all">
        <span>我要陪跑</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20">
    <div class="flex flex-col items-center gap-2 text-ash/30">
      <span class="text-xs font-inter tracking-widest uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-ember/50 to-transparent"></div>
    </div>
  </div>
</section>
