---
const pillars = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="3"/><path d="M7 22v-3M17 22v-3M12 18v4"/></svg>`,
    title: 'AI × FDE 思維',
    desc: '不坐教室背單字，嵌入你自己的戰場，用 AI 即時解題。遇到不懂的立刻問，AI 不會笑你。',
    accent: 'ember',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
    title: '《一如既往》精神',
    desc: '不預測，專注不變的事。持續 > 衝刺，敢用 > 完美。21 天養成習慣，比一次性爆發更重要。',
    accent: 'flame',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`,
    title: '你的戰場',
    desc: 'PR、提案、簡報、面試——每人帶自己的英文痛點進來。這個團幫你把自己的英文用起來。',
    accent: 'glow',
  },
];
---

<section class="py-32 px-6 bg-white dark:bg-[#0f0f0f] relative overflow-hidden" id="pillars">
  <!-- Subtle bg texture -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23FF6B35\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

  <div class="max-w-5xl mx-auto relative z-10">
    <!-- Section header -->
    <div class="text-center mb-20">
      <p class="text-ember font-inter text-sm tracking-widest uppercase mb-4">核心架構</p>
      <h2 class="text-4xl md:text-5xl font-black text-coal dark:text-ash mb-4">
        三大支柱
      </h2>
      <p class="text-muted text-lg max-w-lg mx-auto">
        不是教你，是陪你用自己的方式把英文用起來
      </p>
    </div>

    <!-- Pillar cards -->
    <div class="grid md:grid-cols-3 gap-6">
      {pillars.map((pillar, index) => (
        <div class="group relative bg-white dark:bg-[#1a1a1a] rounded-2xl p-8 border border-coal/10 dark:border-white/10 hover:border-ember/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-ember/10">
          <!-- Accent line top -->
          <div class={`absolute top-0 left-8 right-8 h-0.5 bg-gradient-to-r from-transparent via-${pillar.accent} to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-full`}></div>

          <!-- Number -->
          <span class={`absolute top-6 right-6 text-6xl font-black text-coal/5 dark:text-white/5 select-none`}>
            {String(index + 1).padStart(2, '0')}
          </span>

          <!-- Icon -->
          <div class={`w-14 h-14 rounded-xl bg-${pillar.accent}/10 text-${pillar.accent} flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300`} set:html={pillar.icon} />

          <h3 class="text-xl font-black text-coal dark:text-ash mb-3">{pillar.title}</h3>
          <p class="text-muted leading-relaxed">{pillar.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
