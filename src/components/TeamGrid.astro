---
const team = {
  leaders: [
    { name: 'dar（小隊長）', role: '發起人', tag: 'PR / 英文不够好' },
  ],
  members: [
    { name: '隊員 A', role: '隊員', tag: '口說' },
    { name: '隊員 B', role: '隊員', tag: '寫作' },
  ],
  pacemakers: [
    { name: '陪跑員 1', role: '陪跑員', tag: '有留學經驗' },
    { name: '陪跑員 2', role: '陪跑員', tag: '多益 900+' },
  ],
};

const colorMap = ['bg-ember', 'bg-flame', 'bg-accent', 'bg-glow'];

function getAvatarColor(name: string) {
  return colorMap[name.length % colorMap.length];
}

const groups = [
  { title: '小隊長 / 助教', data: team.leaders, accent: 'ember' },
  { title: '隊員', data: team.members, accent: 'ash' },
  { title: '陪跑員', data: team.pacemakers, accent: 'accent' },
];
---

<section class="py-32 px-6 bg-coal relative overflow-hidden" id="team">
  <!-- Ambient glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/4 w-[400px] h-[400px] rounded-full bg-ember/5 blur-[100px]"></div>
    <div class="absolute top-1/2 right-1/4 w-[300px] h-[300px] rounded-full bg-accent/5 blur-[80px]"></div>
  </div>

  <div class="max-w-5xl mx-auto relative z-10">
    <!-- Header -->
    <div class="text-center mb-20">
      <p class="text-ember font-inter text-sm tracking-widest uppercase mb-4">燃燒中的伙伴</p>
      <h2 class="text-4xl md:text-5xl font-black text-ash mb-4">本隊名單</h2>
      <p class="text-ash/50 text-lg">4-8 人的小隊，一起走 21 天</p>
    </div>

    <div class="space-y-12">
      {groups.map(group => (
        <div>
          <!-- Group label -->
          <div class="flex items-center gap-4 mb-6">
            <span class="text-xs font-inter tracking-widest uppercase text-ash/30">{group.title}</span>
            <div class="flex-1 h-px bg-gradient-to-r from-ash/10 to-transparent"></div>
          </div>

          <!-- Members -->
          <div class="flex flex-wrap gap-4">
            {group.data.map(m => (
              <div class="group flex items-center gap-4 px-5 py-4 rounded-2xl bg-white/5 border border-white/10 hover:border-ember/40 hover:bg-white/10 transition-all duration-300 hover:-translate-y-0.5">
                <!-- Avatar -->
                <div class={`w-12 h-12 ${getAvatarColor(m.name)} rounded-xl flex items-center justify-center text-coal font-black text-lg flex-shrink-0 group-hover:scale-105 transition-transform`}>
                  {m.name.charAt(0)}
                </div>
                <!-- Info -->
                <div class="min-w-0">
                  <p class="font-bold text-ash text-sm truncate">{m.name}</p>
                  <p class="text-xs text-ember/70">{m.tag}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
