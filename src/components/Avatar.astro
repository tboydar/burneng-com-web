---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = '' } = Astro.props;
const initials = name.charAt(0);
const colors = ['bg-ember', 'bg-flame', 'bg-accent', 'bg-glow'];
const color = colors[name.length % colors.length];
---

<div class={`w-12 h-12 ${color} rounded-full flex items-center justify-center text-coal font-black text-lg ${className}`}>
  {initials}
</div>
