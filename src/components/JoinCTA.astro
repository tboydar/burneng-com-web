---
const perks = [
  '不限職業、不限英文程度',
  '每天 10 分鐘，用碎片時間',
  '有 AI 訂閱加分、有《原子習慣》加分（但都不是必要）',
  '4-8 人小隊，有人陪跑不孤單',
];
---

<section class="py-32 px-6 bg-white dark:bg-[#0f0f0f] relative overflow-hidden" id="join">
  <!-- Glow accent -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[300px] bg-ember/10 blur-[100px] rounded-full pointer-events-none"></div>

  <div class="max-w-xl mx-auto relative z-10">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-ember font-inter text-sm tracking-widest uppercase mb-4">最後一步</p>
      <h2 class="text-4xl md:text-5xl font-black text-coal dark:text-ash mb-4">
        如何加入？
      </h2>
    </div>

    <!-- Perks list -->
    <ul class="space-y-4 mb-12">
      {perks.map((perk, i) => (
        <li class="flex items-center gap-4 p-4 bg-coal/5 dark:bg-white/5 rounded-xl border border-coal/10 dark:border-white/10">
          <span class={`flex-shrink-0 w-8 h-8 rounded-full bg-ember/10 text-ember flex items-center justify-center text-sm font-black`}>
            {String(i + 1).padStart(2, '0')}
          </span>
          <span class="text-coal/80 dark:text-ash/80">{perk}</span>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <div class="text-center">
      <a
        href="https://discord.gg"
        target="_blank"
        rel="noopener noreferrer"
        class="group relative inline-flex items-center gap-3 px-10 py-5 bg-ember text-coal font-black text-xl rounded-2xl overflow-hidden transition-all hover:scale-105 active:scale-95 shadow-xl shadow-ember/30 hover:shadow-ember/50"
      >
        <span class="relative z-10">留言「我要 AI 共燃！」</span>
        <span class="relative z-10 text-2xl">🔥</span>
        <div class="absolute inset-0 bg-gradient-to-r from-flame via-ember to-flame opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </a>
      <p class="mt-6 text-sm text-muted flex items-center justify-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.032.056a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
        想陪跑？留言「我要陪跑」
      </p>
    </div>
  </div>
</section>
