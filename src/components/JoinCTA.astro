---
const perks = [
  '不限職業、不限英文程度',
  '每天 10 分鐘，用碎片時間',
  '有 AI 訂閱加分、有《原子習慣》加分（但都不是必要）',
  '4-8 人小隊，有人陪跑不孤單',
];
---

<section class="py-32 px-6 bg-white dark:bg-[#0f0f0f] relative overflow-hidden" id="join">
  <!-- Glow accent -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[300px] bg-ember/10 blur-[100px] rounded-full pointer-events-none"></div>

  <div class="max-w-xl mx-auto relative z-10">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-ember font-inter text-sm tracking-widest uppercase mb-4">最後一步</p>
      <h2 class="text-4xl md:text-5xl font-black text-coal dark:text-ash mb-4">
        如何加入？
      </h2>
    </div>

    <!-- Perks list -->
    <ul class="space-y-4 mb-12">
      {perks.map((perk, i) => (
        <li class="flex items-center gap-4 p-4 bg-coal/5 dark:bg-white/5 rounded-xl border border-coal/10 dark:border-white/10">
          <span class={`flex-shrink-0 w-8 h-8 rounded-full bg-ember/10 text-ember flex items-center justify-center text-sm font-black`}>
            {String(i + 1).padStart(2, '0')}
          </span>
          <span class="text-coal/80 dark:text-ash/80">{perk}</span>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <div class="text-center">
      <a
        href="/join"
        class="group relative inline-flex items-center gap-3 px-10 py-5 bg-ember text-coal font-black text-xl rounded-2xl overflow-hidden transition-all hover:scale-105 active:scale-95 shadow-xl shadow-ember/30 hover:shadow-ember/50"
      >
        <span class="relative z-10">我要報名！</span>
        <span class="relative z-10 text-2xl">🔥</span>
        <div class="absolute inset-0 bg-gradient-to-r from-flame via-ember to-flame opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </a>
      <p class="mt-6 text-sm text-muted flex items-center justify-center gap-2">
        填表就加入我們，4-8 人小隊一起走 21 天
      </p>
    </div>
  </div>
</section>
