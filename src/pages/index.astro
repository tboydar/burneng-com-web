---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Pillars from '../components/Pillars.astro';
import AtomicHabit from '../components/AtomicHabit.astro';
import TeamGrid from '../components/TeamGrid.astro';
import JoinCTA from '../components/JoinCTA.astro';
---

<BaseLayout title="AI共燃英語團 — 用 AI 把英文燒進日常">
  <Hero />

  <!-- Why Section -->
  <section class="py-24 px-6 bg-white dark:bg-coal/40" id="why">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-black mb-8 text-coal dark:text-ash">為什麼是這個團？</h2>
      <div class="prose prose-lg">
        <p>夜間部高職出身，學生時期英文就是那種「考試能猜就猜、能混就混」的程度。</p>
        <p>沒有留學經驗，沒有從小雙語環境，就是一個土生土長、靠著工作被逼著用英文的台灣工程師。</p>
        <blockquote class="border-l-4 border-ember pl-6 text-xl font-bold text-ember my-8">
          所以這個團，不是英文很強的人來教你，是一群英文不夠好的人一起用 AI 慢慢變好。
        </blockquote>
      </div>
    </div>
  </section>

  <Pillars />
  <AtomicHabit />

  <!-- Results Section -->
  <section class="py-24 px-6 bg-coal text-ash" id="results">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-black mb-16">預計成果</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          { num: '21', label: '天' },
          { num: '9+', label: '個英文任務產出' },
          { num: '1', label: '份個人常用表達清單' },
          { num: '4-8', label: '人的小隊' },
        ].map(r => (
          <div>
            <p class="text-5xl md:text-6xl font-black italic text-glow">{r.num}</p>
            <p class="text-ash/70 mt-2">{r.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <TeamGrid />
  <JoinCTA />
</BaseLayout>
